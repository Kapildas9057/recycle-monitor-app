rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is super admin
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'kd850539@gmail.com';
    }
    
    // Waste images storage
    match /waste_images/{employee_id}/{imageId} {
      allow create: if request.auth != null && 
                       exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.employee_id == employee_id;
      
      allow read: if isSuperAdmin() || 
                     exists(/databases/$(database)/documents/user_roles/$(request.auth.uid)) &&
                     get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
      
      allow delete: if isSuperAdmin();
    }

    // Complaint images — public upload, admin read/delete
    match /complaint_images/{fileName} {
      // Anyone can upload images with complaints
      allow create: if request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      
      // Anyone can read (to display in form confirmation & admin dashboard)
      allow read: if true;

      // Only super admin can delete
      allow delete: if isSuperAdmin();
    }
  }
}
